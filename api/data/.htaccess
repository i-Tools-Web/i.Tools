# Deny all direct access to data directory
# SQLite DBs, uploaded files, and stored snippets live here — they must not be
# served to the public. All access goes through /api/*.php which enforces rules.

# Apache 2.4+
<IfModule mod_authz_core.c>
  Require all denied
</IfModule>

# Apache 2.2
<IfModule !mod_authz_core.c>
  Order deny,allow
  Deny from all
</IfModule>

# Block all file extensions just to be safe
<FilesMatch ".*">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Disable any script execution
Options -ExecCGI -Indexes
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .pl .py .jsp .asp .sh .cgi
AddType text/plain .php .phtml .sh .pl .py

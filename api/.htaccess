# Allow PHP execution in /api but deny directory listing
Options -Indexes
DirectoryIndex index.php

# Protect .db/.sqlite/.log files at this level too (defence in depth)
<FilesMatch "\.(db|sqlite|sqlite3|log|ini|env)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>
